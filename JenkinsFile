pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker{
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
        stage ('Test') {
            echo 'Test stage'
        }
            steps {
                echo 'Hello World'
                    sh '''
                        ls -la
                        node --version
                        npm --version
                        npm ci
                        npm run build 
                        ls -la
                    '''
                
            }
        }
    }
}
